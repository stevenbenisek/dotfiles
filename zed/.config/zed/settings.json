{
  "agent": {
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5-latest"
    },
    "enable_feedback": false
  },
  "features": {
    "edit_prediction_provider": "copilot"
  },
  "icon_theme": "Material Icon Theme",
  "tabs": {
    "file_icons": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "font_size": 14.0,
    "font_family": "FiraCode Nerd Font"
  },
  "theme": {
    "dark": "Tokyo Night",
    "light": "Tokyo Night Light",
    "mode": "system"
  }
}
